{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@nexasistem/shared": ["packages/shared/src/index.ts"],
      "@nexasistem/auth": ["packages/auth/src/index.ts"],
      "@nexasistem/db": ["packages/db/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", ".wrangler"]
}
